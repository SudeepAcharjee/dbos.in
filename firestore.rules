rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // SUPER ADMIN — Full access helper
    // ─────────────────────────────────────────────
    function isSuperAdmin() {
      return request.auth.uid == "hmAvRUEq5SchddjQRukAFxEUeh43";
    }

    // ─────────────────────────────────────────────
    // STAFF — Access helper
    // ─────────────────────────────────────────────
    function isStaff() {
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // PARTNER — Access helper
    // ─────────────────────────────────────────────
    function isPartner() {
      return exists(/databases/$(database)/documents/facilitation-partner/$(request.auth.uid));
    }

    function isAdmin() {
      return request.auth != null && (
        isSuperAdmin() ||
        isStaff() ||
        isPartner() ||
        exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/studycentres/$(request.auth.uid))
      );
    }

    // ─────────────────────────────────────────────
    // STUDENT — Access helper
    // ─────────────────────────────────────────────
    function isValidStudent() {
      return exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // NOTIFICATIONS COLLECTION
    // ─────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Allow students to mark notifications as read in their specific sub-collection
      match /{enrollmentId}/{statusDoc} {
        allow read, write: if request.auth != null;
      }
    }
    
    // ─────────────────────────────────────────────
    // EMAIL OTP COLLECTION
    // ─────────────────────────────────────────────
    match /emailOtps/{otpId} {
      allow read, write: if false;
      allow read: if request.auth != null && isSuperAdmin();
    }

    // ─────────────────────────────────────────────
    // USER NOTIFICATIONS COLLECTION
    // ─────────────────────────────────────────────
    match /user_notifications/{userNotificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    // COORDINATORS COLLECTION
    // ─────────────────────────────────────────────
    match /coordinators/{coordId} {
      allow read; // Website can read without login
      allow write: if request.auth != null
                   && (isSuperAdmin() || request.auth.uid == coordId);
    }

    // ─────────────────────────────────────────────
    // STUDY CENTRES COLLECTION
    // ─────────────────────────────────────────────
    match /studycentres/{scId} {
      allow read; // Website can read without login
      allow write: if request.auth != null
                   && (isSuperAdmin() || request.auth.uid == scId);
    }

    // ─────────────────────────────────────────────
    // COUNSELLING CENTRES COLLECTION
    // ─────────────────────────────────────────────
    match /counsellingcentres/{centreId} {
      allow read; // Website can read without login
      allow write: if request.auth != null
                   && (isSuperAdmin() || request.auth.uid == centreId);
    }

    // ─────────────────────────────────────────────
    // FACILITATION PARTNER COLLECTION
    // ─────────────────────────────────────────────
    match /facilitation-partner/{partnerId} {
      allow read; // Website can read without login
      allow write: if request.auth != null
                   && (isSuperAdmin() || request.auth.uid == partnerId);
    }

    // ─────────────────────────────────────────────
    // ENROLLED STUDENTS COLLECTION
    // ─────────────────────────────────────────────
    match /enrolled-students/{studentId} {
      allow read, write, update, delete: if request.auth != null && (
        isSuperAdmin() ||
        isStaff() ||
        exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/studycentres/$(request.auth.uid)) ||
        isPartner()
      );

      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.email == resource.data.email;
    }

   // ─────────────────────────────────────────────
    // STUDENTS COLLECTION
    // ─────────────────────────────────────────────
    match /students/{studentId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      // Original Strict Rule: allow read, write: if request.auth != null && request.auth.uid == studentId;
      
      // Public read access for result portal, authenticated write/update
      allow read: if true; 
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────────
    // STUDY-MATERIALS COLLECTION
    // ─────────────────────────────────────────────
    match /study-materials/{materialId} {
      // Super Admin and Staff → full access
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());

      // Students → read only
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // SESSIONS COLLECTION
    // ─────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      
      // Allow read for students, coordinators, counselling centres, study centres, and public
      allow read: if true || 
        (request.auth != null && (
          exists(/databases/$(database)/documents/students/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/studycentres/$(request.auth.uid))
        ));
    }

    // ─────────────────────────────────────────────
    // MEDIUM COLLECTION
    // ─────────────────────────────────────────────
    match /medium/{mediumId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      
      // Allow read for students, coordinators, counselling centres, study centres, and public
      allow read: if true || 
        (request.auth != null && (
          exists(/databases/$(database)/documents/students/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/studycentres/$(request.auth.uid))
        ));
    }

    // ─────────────────────────────────────────────
    // MODE COLLECTION
    // ─────────────────────────────────────────────
    match /mode/{modeId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      
      // Allow read for students, coordinators, counselling centres, study centres, and public
      allow read: if true || 
        (request.auth != null && (
          exists(/databases/$(database)/documents/students/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/studycentres/$(request.auth.uid))
        ));
    }

    // ─────────────────────────────────────────────
    // CLASS COLLECTION
    // ─────────────────────────────────────────────
    match /class/{classId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      
      // Allow read for students, coordinators, counselling centres, study centres, and public
      allow read: if true || 
        (request.auth != null && (
          exists(/databases/$(database)/documents/students/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/studycentres/$(request.auth.uid))
        ));
    }

    // ─────────────────────────────────────────────
    // REQUESTED COUNSELLING COLLECTION
    // ─────────────────────────────────────────────
    match /requested-counselling/{reqId} {
      allow read, write: if request.auth != null && (
        isSuperAdmin() ||
        isStaff() ||
        request.auth.uid == resource.data.coordinatorId ||
        request.auth.uid == request.resource.data.coordinatorId ||
        isPartner()
      );
    }

    // ─────────────────────────────────────────────
    // REQUESTED STUDY CENTRE COLLECTION
    // ─────────────────────────────────────────────
    match /requested-studycentre/{reqId} {
      allow read, write: if request.auth != null && (
        isSuperAdmin() ||
        isStaff() ||
        request.auth.uid == resource.data.coordinatorId ||
        request.auth.uid == request.resource.data.coordinatorId ||
        isPartner()
      );
    }

    // ─────────────────────────────────────────────
    // COUNSELLING-WEB COLLECTION
    // ─────────────────────────────────────────────
    match /counselling-web/{docId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    // ─────────────────────────────────────────────
    // AUDIT LOGS COLLECTION
    // ─────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // COORDINATOR-WEB COLLECTION
    // ─────────────────────────────────────────────
    match /coordinator-web/{docId} {
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        isStaff() || 
        resource.data.email.lower() == request.auth.token.email.lower()
      );
      allow write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    // ─────────────────────────────────────────────
    // STUDYCENTRE-WEB COLLECTION
    // ─────────────────────────────────────────────
    match /studycentre-web/{docId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    // ─────────────────────────────────────────────
    // REQUESTED-FACILITATION-PARTNERS COLLECTION
    // ─────────────────────────────────────────────
    match /requested-facilitation-partners/{docId} {
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        isStaff() || 
        resource.data.email.lower() == request.auth.token.email.lower()
      );
      allow write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    // ─────────────────────────────────────────────
    // REGISTRATION COLLECTIONS (for center approvals)
    // ─────────────────────────────────────────────
    match /study_center_registrations/{registrationId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    match /counselling_center_registrations/{registrationId} {
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
      allow create: if request.auth == null;
    }

    // ─────────────────────────────────────────────
    // ASSIGNMENTS COLLECTION
    // ─────────────────────────────────────────────
    match /assignments/{assignmentId} {
      // Super Admin, Staff, and Students → full access
      allow read, write, update, delete: if request.auth != null && (
        isSuperAdmin() ||
        isStaff() ||
        exists(/databases/$(database)/documents/students/$(request.auth.uid))
      );

      // Coordinators, Counselling Centres, Study Centres → read only
      allow read: if request.auth != null && (
        exists(/databases/$(database)/documents/coordinators/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/counsellingcentres/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/studycentres/$(request.auth.uid)) ||
        isPartner()
      );
    }

    // ─────────────────────────────────────────────
    // STAFF COLLECTION
    // ─────────────────────────────────────────────
    match /staff/{staffId} {
      allow read, write, update, delete, create: if request.auth != null && isSuperAdmin();
      allow read, write, update, delete: if request.auth != null && request.auth.uid == staffId;
    }

    // ─────────────────────────────────────────────
    // CLASS-LINK COLLECTION
    // ─────────────────────────────────────────────
    match /class-links/{linkId} {
      // Super Admin and Staff → full access
      allow read, write, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());

      // Students → read only
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // CONTACT-FORM COLLECTION
    // ─────────────────────────────────────────────
    match /contact-form/{formId} {
      // Anyone (including non-authenticated users) can create/submit
      allow create: if true;
      
      // Only Super Admin or Staff can read, update, and delete
      allow read, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
    }

    // ─────────────────────────────────────────────
    // NOTICE COLLECTION
    // ─────────────────────────────────────────────
    match /notice/{noticeId} {
      // Anyone can read notices (public website)
      allow read: if true;

      // Only Super Admin or Staff can manage notices
      allow create, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());
    }

		// ---------------------------------------------
		// EXAMS
    //----------------------------------------------
    match /exams/{examId} {

      // Public read access for result portal
      allow read: if true;

      // Super Admin or Staff → full access
      allow create, update, delete: if request.auth != null && (isSuperAdmin() || isStaff());

      // Students → update only specific fields (application-related)
      // Note: Reverting to simple auth check because strict diff() rule is failing unexpectedly.
      allow update: if request.auth != null;
      
      // ─────────────────────────────────────────────
      // APPLICATIONS SUBCOLLECTION
      // ─────────────────────────────────────────────
      match /applications/{studentId} {
        
        allow read, write: if request.auth != null;
        
        // Update/Delete: Only Admin (Deprecated by line above, but keeping for clarity of intent if needed separately)
        // allow update, delete: if request.auth != null && isSuperAdmin();
      }
    }

    // ─────────────────────────────────────────────
    // QUESTIONS COLLECTION (MCQ Integration)
    // ─────────────────────────────────────────────
    match /questions/{questionId} {
      // Admin, Super Admin and Staff -> Full Access (create, read, update, delete)
      allow read, write, update, delete: if isAdmin();
      
      // Students -> Read only (for taking exams)
      // They should only read questions if they are enrolled/have permission (handled by app logic + this basic check)
      allow read: if request.auth != null && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // MCQ-ANSWERS COLLECTION (Student Exam Answers)
    // ─────────────────────────────────────────────
    match /mcq-answers/{examTitle} {
      // Admin, Super Admin and Staff -> Full Access
      allow read, write, update, delete: if isAdmin();
      
      // Students -> Can read and write their own answers
      // Students can read the entire document to see all submissions (for review purposes)
      // Students can write/update their own enrollment number array within the document
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // SECURITY COLLECTION (Exam Security Verification)
    // ─────────────────────────────────────────────
    match /security/{examTitle} {
      // Admin, Super Admin and Staff -> Full Access
      allow read, write, update, delete: if isAdmin();
      
      // Students -> Can read and write their own security verification data
      allow read, write: if request.auth != null && isValidStudent();
    }

    // ─────────────────────────────────────────────
    // SUBMISSIONS COLLECTION
    // ─────────────────────────────────────────────
    match /submissions/{examTitle} {
      // Admin, Super Admin and Staff -> Full Access
      allow read, write, update, delete: if isAdmin();
      
      // Students -> Can read and write
      allow read, write: if request.auth != null && isValidStudent();
    }

    // ─────────────────────────────────────────────
    // VERIFY COLLECTION (Results Backup)
    // ─────────────────────────────────────────────
    match /verify/{examTitle} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // MAINTAINENCE COLLECTION
    // ─────────────────────────────────────────────
    match /maintainence/{docId} {
      allow read: if true;
      allow write, update, delete: if request.auth != null && isSuperAdmin();
    }

    // ─────────────────────────────────────────────
    // APK VERSION COLLECTION
    // ─────────────────────────────────────────────
    match /apk-version/{docId} {
      // Public read access
      allow read: if true;
      // Only Super Admin can write
      allow write, update, delete: if request.auth != null && isSuperAdmin();
    }
  }
}
 